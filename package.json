{
  "name": "agripower-backend",
  "version": "1.0.0",
  "description": "Backend API for Electric Power Distribution for Agriculture",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "seed": "node backend/utils/seed.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "keywords": [
    "agriculture",
    "power-distribution",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}